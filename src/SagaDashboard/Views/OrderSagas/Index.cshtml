@using OrderSaga.Saga
@model IEnumerable<OrderSagaState>

<h1>Order Sagas</h1>

<form method="get" class="form-inline mb-3">
    <div class="form-group mr-2">
        <input type="number" name="orderId" class="form-control" placeholder="Order Id" value="@ViewBag.OrderId" />
    </div>
    <div class="form-group mr-2">
        <select name="state" class="form-control">
            <option value="">All states</option>
            @foreach (var s in new[] { "Initial", "CheckingInventory", "ProcessingPayment", "Confirmed", "Failed" })
            {
                <option value="@s" selected="@(s == (string)ViewBag.State)">@s</option>
            }
        </select>
    </div>
    <button type="submit" class="btn btn-primary mr-2">Filter</button>
    <a asp-action="Index" class="btn btn-secondary">Clear</a>
</form>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Order Id</th>
            <th>Customer</th>
            <th>Order Date</th>
            <th>Total Amount</th>
            <th>Saga State</th>
            <th>Retry Count</th>
            <th>Next Call</th>
            <th>Correlation Id</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var saga in Model)
        {
            <tr>
                <td>@saga.Order?.Id</td>
                <td>@saga.Order?.CustomerName</td>
                <td>@saga.Order?.OrderDate</td>
                <td>@saga.Order?.TotalAmount</td>
                <td>@saga.CurrentState</td>
                <td>@saga.InventoryRetryCount</td>
                <td>
                    @(saga.NextInventoryRetryAt.HasValue
            ? DateTime.SpecifyKind(saga.NextInventoryRetryAt.Value, DateTimeKind.Utc).ToLocalTime().ToString("yyyy-MM-dd hh:mm:ss tt")
            : "-")
                </td>
                <td>@saga.CorrelationId</td>
                <td>
                    @if (saga.CurrentState == "Failed")
                    {
                        <a asp-action="Edit" asp-route-correlationId="@saga.CorrelationId" class="btn btn-sm btn-warning">Edit &amp; Restart</a>
                    }
                    else if (saga.CurrentState == "CheckingInventory")
                    {
                        <a asp-action="Edit" asp-route-correlationId="@saga.CorrelationId" class="btn btn-sm btn-info">Edit Items</a>
                    }
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center">No sagas found.</td>
            </tr>
        }
    </tbody>
</table>
