@using Application.Dtos
@model OrderDto

@{
    var sagaState = (string)ViewBag.SagaState;
    var targetAction = sagaState == "Failed" ? "Restart" : "UpdateInFlight";
}

<h1>Edit Order @Model.Id (@sagaState Saga)</h1>

@if (sagaState == "CheckingInventory")
{
    <p class="text-muted">Saga is retrying inventory checks. Saving updates the order in place — the next scheduled retry will re-check stock against the corrected line items.</p>
}

<form asp-action="@targetAction" asp-route-correlationId="@Context.Request.Query["correlationId"]" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Customer Name</label>
        <input asp-for="CustomerName" class="form-control" />
    </div>

    <h4 class="mt-3">Order Products</h4>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Product</th>
                <th>Quantity</th>
                <th>Unit Price</th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.OrderDetails.Count; i++)
            {
                <tr>
                    <td>
                        <input type="hidden" asp-for="OrderDetails[i].Id" />
                        <select asp-for="OrderDetails[i].ProductId" class="form-control">
                            @foreach (var p in (List<ProductDto>)ViewBag.Products)
                            {
                                <option value="@p.Id" selected="@(p.Id == Model.OrderDetails[i].ProductId)">@p.Name (stock: @p.Stock)</option>
                            }
                        </select>
                    </td>
                    <td><input asp-for="OrderDetails[i].OrderQty" type="number" min="1" class="form-control" /></td>
                    <td><input asp-for="OrderDetails[i].UnitPrice" type="number" step="0.01" class="form-control" /></td>
                </tr>
            }
        </tbody>
    </table>

    <button type="submit" class="btn btn-primary">@(sagaState == "Failed" ? "Save & Restart Saga" : "Save & Continue Retrying")</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
